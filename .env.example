DEBUG=true
LOG_LEVEL=info

WITH_METRICS=false
METRICS_NAMESPACE=company

WITH_TRACING=false
JAEGER_ADDRESS=

GRPC_PORT=5050
HTTP_PORT=80
HTTP_CORS=true

PG_DSN="postgres://user:password@localhost:5432/database?sslmode=disable"

# Префикс имён k8s-секретов, создаваемых kusec (плавный переход с helm-секретов)
KUBE_SECRET_NAME_PREFIX=kusec-
